    {
        "id": "init_function",
        "type": "function",
        "z": "224cfad3ce47e7ce",
        "g": "100b19a6e99d2564",
        "name": "Set Default Variables",
        "func": "// Bezpečně načteme existující data (pokud už Victron něco poslal těsně po startu)\n// Pokud data ještě neexistují, vytvoříme nový prázdný objekt.\nlet currentData = flow.get(\"data\") || {};\n\n// Nastavíme výchozí spotřebu tepelného čerpadla (W)\ncurrentData.hp = 2400;\n\n// Uložíme bezpečně zpět do flow kontextu\nflow.set(\"data\", currentData);\n\n// Zobrazení stavu pod nodem pro vizuální kontrolu\nnode.status({fill:\"green\", shape:\"dot\", text:\"Data initialized\"});\n\nreturn msg;",
