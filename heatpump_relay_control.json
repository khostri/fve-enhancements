    {
        "id": "9f388f73cbf1bb37",
        "type": "function",
        "z": "224cfad3ce47e7ce",
        "g": "f16635b09b6de84c",
        "name": "Evaluate And Control",
        "func": "// ── Read inputs from flow context ───────────────────────────────\nconst data    = flow.get(\"data\") || {};\nconst l1      = Number(data.l1      || 0);   // Grid L1 [W], negative = export\nconst l2      = Number(data.l2      || 0);   // Grid L2 [W]\nconst l3      = Number(data.l3      || 0);   // Grid L3 [W]\nconst soc     = Number(data.soc     || 0);   // Battery SOC [%]\nconst bp      = Number(data.bp      || 0);   // Battery power [W]\nconst fd      = Number(data.feed    || 0);   // 0=export OK, 1=prevent export\nconst rly2    = Number(data.rly2    || 0);   // Relay: 0=off, 1=on\nconst day     = Number(data.day     || 0);   // 1=weekday active window (11:00→sunset)\nconst weekend = Number(data.weekend || 0);   // 1=Sat/Sun active window (sunrise→sunset)\nconst hp      = Number(data.hp      || 2400); // Est. heatpump consumption [W]\n\n// OR logic: active if weekday window OR weekend window\nconst isActive = (day === 1) || (weekend === 1);\n\nlet counter    = context.get(\"counter\") || 0;\nconst ON_THRESH  =  72;\nconst OFF_THRESH = -72;\nconst MAX_CNT    = ON_THRESH  + 10;\nconst MIN_CNT    = OFF_THRESH - 10;\n\n// ── Emergency: battery discharging at very high rate ────────────\nif (bp < -10000) { counter = ON_THRESH + 1; }\n\n// ── Relay OFF: decide whether to turn ON ────────────────────────\nif (rly2 === 0) {\n    if (isActive) {\n        if (fd === 0) {\n            // Grid export OK: check surplus covers HP even when running\n            if ((l1 + l2 + l3 + hp) < 0) counter += 2;\n            else                          counter -= 3;\n        } else {\n            // Grid export prevented: use SOC as proxy\n            if (soc > 66) counter += 2;\n            else          counter -= 3;\n        }\n    } else {\n        // Outside active window (night / before 11:00 on weekdays)\n        counter -= 5;\n    }\n}\n\n// ── Relay ON: decide whether to keep ON (or turn OFF) ───────────\nif (rly2 === 1) {\n    if (isActive) {\n        if (fd === 0) {\n            if ((l1 + l2 + l3) < -100 && soc > 90) counter += 1;\n            else                                     counter -= 1;\n        } else {\n            if (soc > 66) counter += 1;\n            else          counter -= 1;\n        }\n    } else {\n        // Outside active window: turn off\n        counter -= 3;\n    }\n}\n\n// ── Clamp ────────────────────────────────────────────────────────\ncounter = Math.max(MIN_CNT, Math.min(MAX_CNT, counter));\nconst displayCounter = counter;\n\n// ── Output ───────────────────────────────────────────────────────\nlet command = null;\nif (counter >= ON_THRESH) {\n    command = 1;\n    context.set(\"counter\", Math.round(counter / 2));\n} else if (counter <= OFF_THRESH) {\n    command = 0;\n    context.set(\"counter\", Math.round(counter / 2));\n} else {\n    context.set(\"counter\", counter);\n}\n\n// ── Node status ──────────────────────────────────────────────────\nconst modeStr = weekend === 1 ? \"wknd\" : (day === 1 ? \"day\" : \"off-time\");\nnode.status({\n    fill:  rly2 === 1 ? \"green\" : \"gray\",\n    shape: \"dot\",\n    text:  \"Cnt:\" + displayCounter\n         + \" | \" + (rly2 === 1 ? \"ON\" : \"OFF\")\n         + \" | SOC:\" + soc + \"%\"\n         + \" | \" + modeStr\n});\n\nif (command !== null) { return { payload: command }; }\nreturn null;",
